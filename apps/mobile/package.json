{
  "name": "@music-app/mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "electron:dev": "npm run build:web && electron electron-main.js",
    "electron:build": "npm run build:web && electron-builder",
    "desktop": "electron electron-main.js",
    "build:windows": "npm run build:web && electron-builder build --windows"
  },
  "build": {
    "appId": "com.musiki.app",
    "productName": "Expo Music App",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "dist_electron"
    },
    "extraMetadata": {
      "main": "electron-main.js"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "assets/desktop-icon.png",
      "!node_modules/**/*",
      "!**/*.map"
    ],
    "win": {
      "target": "nsis",
      "icon": "./assets/desktop-icon.png"
    }
  },
  "dependencies": {
    "@music-app/firebase": "*",
    "@music-app/store": "*",
    "@music-app/types": "*",
    "@music-app/utils": "*",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "axios": "^1.14.0",
    "expo": "~54.0.33",
    "expo-asset": "^55.0.15",
    "expo-audio": "~1.1.1",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "expo-video": "~3.0.16",
    "firebase": "^12.11.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.1",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.3",
    "react-native-dotenv": "^3.4.11",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.8.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@types/react": "~19.1.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "babel-preset-expo": "^54.0.10",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "private": true
}