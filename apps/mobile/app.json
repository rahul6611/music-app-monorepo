{
  "expo": {
    "name": "Musiki",
    "slug": "music-reactnative-prototype",
    "version": "1.0.0",
    "scheme": "musiki",
    "orientation": "portrait",
    "icon": "./assets/splash-musiki.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "notification": {
      "icon": "./assets/splash-musiki.png",
      "color": "#ffffff"
    },
    "splash": {
      "image": "./assets/splash-musiki.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vekariyarahul6612.musiki",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/splash-musiki.png",
        "backgroundColor": "#121212"
      },
      "edgeToEdgeEnabled": true,
      "statusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#00000000",
        "translucent": true
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA"
      ],
      "package": "com.vekariyarahul6612.musiki"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "5e531deb-680b-4a60-8d6b-ff89c050c49b"
      },
      "router": {}
    },
    "owner": "pb2025org",
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow this app to access your microphone to record audio."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/splash-musiki.png",
          "color": "#ffffff",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow this app to access your camera to record video.",
          "microphonePermission": "Allow this app to access your microphone to record video."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5e531deb-680b-4a60-8d6b-ff89c050c49b"
    }
  }
}
